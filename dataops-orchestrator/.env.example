# Piveau / Data Space
PIVEAU_URL=https://search.dspace.sparkworks.net
DSPACE_URL=https://dspace.sparkworks.net/datasets
DSPACE_CATALOGUE_URL=https://catalogue.dspace.sparkworks.net

# Airflow instance
AIRFLOW_URL=http://localhost:8080
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin

# Orchestrator server
HOST=0.0.0.0
PORT=8000

# Comma-separated origins allowed for CORS (React UI URL)
CORS_ORIGINS=http://localhost:3000

# Override default paths (/srv/data/dags and /srv/data/tasks) for local development
AIRFLOW_DAGS_FOLDER=./generated_dags
AIRFLOW_TASKS_FOLDER=./generated_tasks
AIRFLOW_PLUGINS_FOLDER=../airflow/plugins

# Public URL of this orchestrator — used as dcat:endpointURL when registering services in piveau
ORCHESTRATOR_URL=http://localhost:8000

# piveau-hub write API — for registering dcat:DataService records
PIVEAU_HUB_URL=https://hub.dspace.sparkworks.net
PIVEAU_API_KEY=
PIVEAU_SERVICES_CATALOGUE=6gdali-services
DSPACE_BASE_URL=https://dataspace.6gdali.eu
CODE_REPOSITORY_URL=https://github.com/sparkworks/6gdali-dataops
PUBLISHER_NAME=SparkWorks P.C.
