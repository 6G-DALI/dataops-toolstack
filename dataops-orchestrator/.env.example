# Airflow instance
AIRFLOW_URL=http://localhost:8080
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin

# Orchestrator server
HOST=0.0.0.0
PORT=8000

# Comma-separated origins allowed for CORS (React UI URL)
CORS_ORIGINS=http://localhost:3000

# Override default paths (/srv/data/dags and /srv/data/tasks) for local development
AIRFLOW_DAGS_FOLDER=./generated_dags
AIRFLOW_TASKS_FOLDER=./generated_tasks
