# Set to true to use mock data instead of a real Airflow instance
MOCK=false

# Airflow instance
AIRFLOW_URL=http://localhost:8080
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin

# Orchestrator server
HOST=0.0.0.0
PORT=8000

# Comma-separated origins allowed for CORS (React UI URL)
CORS_ORIGINS=http://localhost:3000

# Folder where generated DAG Python files are written (real Airflow only)
AIRFLOW_DAGS_FOLDER=/opt/airflow/dags
