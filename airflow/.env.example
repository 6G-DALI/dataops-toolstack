# Piveau API key — used by the publish_quality_to_piveau task
PIVEAU_API_KEY=

# Airflow connection IDs for the S3/MinIO buckets. These are fixed per
# deployment and are NOT overridable per DAG run. Both default to
# "dali-dataspace" if unset.
#   DATASPACE_S3_CONN_ID — source Data Space bucket (dali_dataspace_validate_dataset)
#   DATAOPS_S3_CONN_ID   — DataOps destination bucket (EDC transfer / demo)
DATASPACE_S3_CONN_ID=dali-dataspace
DATAOPS_S3_CONN_ID=dali-dataspace

# Airflow user ID — must match the user running Docker on your machine
# On Linux/macOS: run `id -u` and paste the result here
AIRFLOW_UID=50000

# Airflow admin credentials (used on first init)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Postgres metadata database credentials (used by postgres and the Airflow
# connection strings). Change these for anything beyond local development.
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# Fernet key used to encrypt Airflow connection/variable secrets at rest.
# Leave empty for local dev; generate one for real deployments with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=

# DataOps Orchestrator — allowed CORS origins for the UI
DATAOPS_CORS_ORIGINS=http://localhost:3000

# Optional: override the Airflow Docker image
# AIRFLOW_IMAGE_NAME=apache/airflow:3.1.8

# Optional: path to a custom .env file (defaults to .env in the same directory)
# ENV_FILE_PATH=.env
